# --- PAYSTACK KEYS ---
# Required for live payment processing.
# Add your Paystack Public Key here to allow frontend popups.
VITE_PAYSTACK_PUBLIC_KEY=
# Add your Paystack Secret Key here to allow backend transaction verification. Keep this secret!
PAYSTACK_SECRET_KEY=

# --- FIREBASE SECRETS ---
# Optional: Needed for the backend to securely update user subscriptions after payment.
# Use the unformatted JSON string downloaded from Firebase Console -> Project Settings -> Service Accounts.
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- GEMINI API KEY ---
# Required for the Server-Side AI Assistant and all generative features of the platform.
GEMINI_API_KEY=
